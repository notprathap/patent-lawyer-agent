{
  "name": "patent-lawyer-agent",
  "version": "0.1.0",
  "description": "Multi-agent patent defensibility analysis system",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:ingest": "tsx scripts/ingest-all.ts",
    "api": "tsx src/api/index.ts",
    "web": "cd web && npm run dev",
    "dev:all": "concurrently --names api,web --prefix-colors blue,green \"npm run api\" \"npm run web\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notprathap/patent-lawyer-agent.git"
  },
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@huggingface/transformers": "^3.8.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.9",
    "fastify": "^5.8.4",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
