# =============================================================================
# Patent Lawyer Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with (REQUIRED), others are optional or for later phases.

# -----------------------------------------------------------------------------
# Claude API (REQUIRED)
# Get your key at https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Database — Neon PostgreSQL (REQUIRED)
# Get your connection string from https://console.neon.tech/
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Patent Search APIs (Phase 2+)
# -----------------------------------------------------------------------------

# EPO Open Patent Services — free, registration required
# Register at https://developers.epo.org/
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=

# SerpAPI — for Google Patents search (optional, paid)
# Get your key at https://serpapi.com/
SERPAPI_API_KEY=

# Semantic Scholar — optional, increases rate limits
# Request at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# -----------------------------------------------------------------------------
# Embedding / RAG (Phase 6+)
# -----------------------------------------------------------------------------

# Voyage AI — for legal document embeddings
# Get your key at https://www.voyageai.com/
VOYAGE_API_KEY=

# -----------------------------------------------------------------------------
# Job Queue — Redis / BullMQ (Phase 8+)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Observability (Phase 9+, optional)
# -----------------------------------------------------------------------------

# Helicone — LLM observability proxy
# Get your key at https://www.helicone.ai/
HELICONE_API_KEY=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
